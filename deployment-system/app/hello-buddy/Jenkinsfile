pipeline {
    agent any

    environment {
        APP_NAME = 'hello-buddy'
        DOCKER_REGISTRY = 'localhost:30500'
        NAMESPACE = 'app'
        HELM_CHART_PATH = './helm'
        VERSION = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Run Tests') {
            agent {
                kubernetes {
                    yaml """
                    apiVersion: v1
                    kind: Pod
                    spec:
                      containers:
                      - name: node
                        image: node:22
                        command:
                        - sleep
                        args:
                        - infinity
                        workingDir: /home/jenkins/agent
                    """
                    defaultContainer 'node'
                }
            }
            steps {
                sh 'node --version'
                sh 'npm --version'

                // Debug npm configuration and network
                sh 'env | grep -i npm'
                sh 'cat ~/.npmrc || echo "No user npmrc"'
                sh 'npm config list -l'
                sh 'curl -v https://registry.npmjs.org/jquery'

                dir('deployment-system/app/hello-buddy') {
                    // Create a completely fresh .npmrc file
                    sh 'rm -f .npmrc'
                    sh 'echo "registry=https://registry.npmjs.org/" > .npmrc'
                    sh 'echo "always-auth=false" >> .npmrc'
                    sh 'echo "strict-ssl=false" >> .npmrc'
                    sh 'echo "proxy=null" >> .npmrc'
                    sh 'echo "https-proxy=null" >> .npmrc'
                    sh 'cat .npmrc'

                    // Set environment variables to override any other config
                    withEnv(['NPM_CONFIG_REGISTRY=https://registry.npmjs.org/',
                             'NPM_CONFIG_PROXY=null',
                             'NPM_CONFIG_HTTPS_PROXY=null',
                             'npm_config_registry=https://registry.npmjs.org/',
                             'HTTP_PROXY=',
                             'HTTPS_PROXY=']) {
                        sh 'npm install --verbose --no-proxy'
                        sh 'npm test'
                    }
                }
            }
            post {
                failure {
                    error "Tests failed! Aborting the pipeline."
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('deployment-system/app/hello-buddy') {
                    sh "docker build -t ${DOCKER_REGISTRY}/${APP_NAME}:${VERSION} ."
                }
            }
        }

        stage('Push to Registry') {
            steps {
                sh "docker push ${DOCKER_REGISTRY}/${APP_NAME}:${VERSION}"
            }
        }

        stage('Update Helm Values') {
            steps {
                dir('deployment-system/app/hello-buddy') {
                    // Update the Helm values.yaml file with the new image tag
                    sh """
                    sed -i 's|tag: .*|tag: ${VERSION}|g' ${HELM_CHART_PATH}/values.yaml
                    sed -i 's|repository: .*|repository: ${DOCKER_REGISTRY}/${APP_NAME}|g' ${HELM_CHART_PATH}/values.yaml
                    """
                }
            }
        }

        stage('Deploy with Helm') {
            steps {
                dir('deployment-system/app/hello-buddy') {
                    sh "helm upgrade --install ${APP_NAME} ${HELM_CHART_PATH} --namespace ${NAMESPACE} --create-namespace"
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                sh "kubectl rollout status deployment/${APP_NAME} -n ${NAMESPACE}"
                sh "kubectl get pods -l app=${APP_NAME} -n ${NAMESPACE}"
            }
        }
    }

    post {
        success {
            echo "Deployment of ${APP_NAME} completed successfully!"
        }
        failure {
            echo "Deployment of ${APP_NAME} failed!"
        }
    }
}
